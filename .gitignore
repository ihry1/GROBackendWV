## ============================================================
##  Editor / OS cruft
## ============================================================
*.swp
*.*~
.DS_Store
*.pyc
project.lock.json
nupkg/

# Visual Studio Code
.vscode/

# Rider / JetBrains
.idea/

## ============================================================
##  Visual Studio per-developer state (never shared)
## ============================================================
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/
*.ipch
*.cache
*.resources
*.dtbcache.json

## ============================================================
##  Build results
##  Trailing-slash (no leading/mid slash) => match at ANY depth.
##  The old "[Bb]in/*" / "[Rr]elease/*" forms were anchored to the
##  repo root and missed nested QuazalWV/bin, GRO_Hook/Release, etc.
## ============================================================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Bb]in/
[Oo]bj/
[Oo]ut/
x64/
x86/
build/
bld/
packages/
msbuild.log
msbuild.err
msbuild.wrn

## ============================================================
##  C/C++ (GRO_Hook) intermediate artifacts
##  Caught by the build-dir rules above too, but listed by
##  extension so stray copies outside Release/ are ignored.
##  NOTE: vendored deps (detours.lib, root streams.exe) live
##  OUTSIDE any build dir and use no blanket *.lib/*.exe rule,
##  so they stay tracked on purpose.
## ============================================================
*.tlog
*.pch
*.exp
*.ilk
*.iobj
*.ipdb
*.recipe
*.lastbuildstate
*.CppClean.log

## ============================================================
##  Misc generated output (pre-existing project rules)
## ============================================================
*.pdb
*.txt
*.bin
*.config
!App.config

# Third-party HexBox control: ignore its working copy
Be.Windows.Forms.HexBox/*

## ============================================================
##  Seeded databases in build folders -- TRACK them despite the
##  build-dir ignores above. git cannot re-include a file whose parent
##  directory is excluded, so re-open each path level (re-ignoring the
##  siblings at each level) down to the DB. Only the live backend DB is
##  tracked here; the DS's bin DB stays ignored (it is empty/0 bytes).
## ============================================================
!GROBackendWV/bin/
GROBackendWV/bin/*
!GROBackendWV/bin/x86/
GROBackendWV/bin/x86/*
!GROBackendWV/bin/x86/Release/
GROBackendWV/bin/x86/Release/*
!GROBackendWV/bin/x86/Release/database.sqlite
